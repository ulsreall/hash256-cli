PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ═══ HASH256 Miner Config ═══════════════════════════════════════
# Optimized for: NVIDIA H100 (109 TFLOPS, 32GB) + AMD EPYC 96-Core

