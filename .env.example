RPC_URL=https://ethereum-rpc.publicnode.com
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ═══ HASH256 Miner Config ═══════════════════════════════════════
# Optimized for: RTX 5090 (31+ GH/s) + EPYC 96-Core

# ─── CPU Miner (npm start) ───────────────────────────────────────
THREADS=46
BATCH_SIZE=200000

# ─── TX Speed (PENTING buat GPU cepat!) ──────────────────────────
MAX_GAS_GWEI=100       # Max base fee gwei (naikin kalau sering skip)
PRIORITY_FEE_GWEI=3    # EIP-1559 priority fee (makin tinggi = TX makin cepat masuk)
GAS_LIMIT=300000
RETRY_DELAY=1000
