# Required
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Backend: auto | cpu | cuda
MINER_BACKEND=auto

# CPU workers (default: cores - 1)
CPU_WORKERS=8

# GPU binary path (auto-detected if empty)
GPU_MINER_BIN=

# Gas
MAX_GAS_GWEI=50
PRIORITY_FEE_GWEI=5
GAS_LIMIT=300000
GAS_REFRESH_MS=4000

# TX Strategy
MAX_PENDING=2
TX_TIMEOUT=45000

# Stats
STATS_INTERVAL=15000
