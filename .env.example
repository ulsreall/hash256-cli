RPC_URL=https://ethereum-rpc.publicnode.com
PRIVATE_KEY=0xPRIVATE_KEY_WALLET_KAMU

# ═══ HASH256 Miner Config ═══════════════════════════════════════

# ─── CPU Miner (npm start) ───────────────────────────────────────
# THREADS=48              # Worker threads (default: CPU count - 1)
# BATCH_SIZE=200000       # Hashes per worker progress report

# ─── GPU Miner (npm run gpu) ─────────────────────────────────────
# GPU auto-detects everything, no config needed

# ─── Shared ──────────────────────────────────────────────────────
# MAX_GAS_GWEI=50         # Skip TX if gas > this (default: 50)
# GAS_LIMIT=300000        # TX gas limit (default: 300000)
# RETRY_DELAY=3000        # Delay on error in ms (default: 3000)
