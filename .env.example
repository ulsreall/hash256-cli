RPC_URL=https://ethereum-rpc.publicnode.com
PRIVATE_KEY=0xPRIVATE_KEY_WALLET_KAMU

# ═══ HASH256 CLI Miner — Config ══════════════════════════════════

# ─── CPU Miner (npm start) ───────────────────────────────────────
# THREADS=8              # Worker threads (default: CPU count - 1)
# BATCH_SIZE=100000      # Hashes per worker progress report

# ─── GPU Miner (npm run gpu) ─────────────────────────────────────
# GPU auto-detects architecture, no extra config needed

# ─── Shared Config ───────────────────────────────────────────────
# MAX_GAS_GWEI=50        # Skip TX if gas > this (default: 50)
# GAS_LIMIT=300000       # TX gas limit (default: 300000)
# RETRY_DELAY=5000       # Delay on error in ms (default: 5000)
