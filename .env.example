RPC_URL=https://ethereum-rpc.publicnode.com
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ═══ HASH256 Miner Config ═══════════════════════════════════════
# Optimized for: 2x RTX 4090 (162.8 TFLOPS, 48GB) + Threadripper 16-Core

